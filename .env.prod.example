# ============================================================
# Production environment for docker-compose.prod.yml
# Copy ke .env.prod, edit nilainya, lalu: make prod-setup
# ============================================================

# === Aplikasi ===
APP_NAME="DK Koi"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# Generate dengan:
#   docker run --rm php:8.4-cli php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=

LOG_LEVEL=warning

# === Database ===
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dk_koi
DB_USERNAME=koi
# Password kuat — generate dengan: openssl rand -base64 24
DB_PASSWORD=GANTI_PASSWORD_KUAT_INI
DB_ROOT_PASSWORD=GANTI_PASSWORD_ROOT_INI

# === Session & cache ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
CACHE_STORE=database
QUEUE_CONNECTION=database

# === Frontend / CORS ===
FRONTEND_URL=http://localhost:8080
SANCTUM_STATEFUL_DOMAINS=localhost:8080

# === Branding (frontend) ===
# Tampil di Login + Sidebar + Header. Ubah supaya per-customer.
VITE_APP_NAME="DK Koi"
VITE_APP_TAGLINE="Platform Inventaris"
VITE_APP_DESCRIPTION="Manajemen inventaris & arus kas"
VITE_APP_YEAR="2026"

# === Mail (opsional) ===
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# === Bcrypt ===
BCRYPT_ROUNDS=12
